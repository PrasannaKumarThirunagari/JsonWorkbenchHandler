{
  "manifest_version": 3,
  "name": "Json Intelligence",
  "version": "1.0.0",
  "description": "Client-side JSON compare, tree explorer, and text compare. Opens in a new tab.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Json Intelligence",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jsonintelligence@jsonintelligence.local",
      "strict_min_version": "109.0"
    }
  }
}
